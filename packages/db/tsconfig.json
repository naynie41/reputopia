{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    // Prisma 7 emits TypeScript source into ./generated. Relax the strictest module
    // flags here so type-checking that generated code doesn't fail on its codegen style.
    "verbatimModuleSyntax": false,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*.ts", "prisma/**/*.ts"]
}
