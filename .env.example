# Sales Roleplay — environment variables (NAMES ONLY, never commit real values).
# Copy to .env and fill in. Validated at boot by packages/config (zod) — a missing
# required var fails fast. Only Phase 0 vars are required today; later-phase keys are
# listed (commented) so this file stays a complete reference.

# ---------------------------------------------------------------------------
# Phase 0 — REQUIRED
# ---------------------------------------------------------------------------

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (auth + orgs/roles). Get keys from the Clerk dashboard (per-env: test vs live).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Svix signing secret for the /api/webhooks/clerk endpoint (user/org sync).
CLERK_WEBHOOK_SIGNING_SECRET=
# Use the in-app sign-in/up pages instead of Clerk's hosted Account Portal.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# After sign-up, go straight to one-time role selection; after sign-in, home routes you.
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/

# Neon Postgres (Prisma).
#   DATABASE_URL = POOLED connection (has "-pooler" in host) — used at runtime.
#   DIRECT_URL   = DIRECT connection (no "-pooler")          — used only for migrations.
DATABASE_URL=
DIRECT_URL=

# LiveKit (live calls + Egress recording). Keys from the LiveKit Cloud project.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Cloudflare R2 (private recordings bucket; S3-compatible).
# Endpoint is derived as https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ---------------------------------------------------------------------------
# Later phases — NOT required yet (uncomment + add to packages/config when wired)
# ---------------------------------------------------------------------------

# Phase 2 — Transcription / scoring / jobs
# ASSEMBLYAI_API_KEY=
# ANTHROPIC_API_KEY=
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Phase 3 — Upstash Redis (matchmaking queue + rate limit)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Phase 6 — Email / observability / analytics
# RESEND_API_KEY=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
